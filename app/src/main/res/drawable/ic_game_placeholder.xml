<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background to maintain aspect ratio and prevent cutting -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <!-- The actual icon centered with enough padding -->
    <item
        android:drawable="@drawable/ic_game"
        android:gravity="center"
        android:top="20dp"
        android:bottom="20dp"
        android:left="40dp"
        android:right="40dp" />
</layer-list>