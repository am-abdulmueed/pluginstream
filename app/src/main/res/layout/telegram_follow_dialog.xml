<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/dialog_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp"
        app:strokeWidth="1.2dp"
        app:strokeColor="#33FFFFFF"
        app:cardBackgroundColor="#1C1C1E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="26dp">

            <TextView
                android:id="@+id/heading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="46dp"
                android:layout_marginHorizontal="20dp"
                android:gravity="center"
                android:text="Join Telegram Official Channel"
                android:textColor="@android:color/white"
                android:textSize="21sp"
                android:fontFamily="@font/google_sans"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="28dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="Join for daily high-speed streaming updates!"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/heading" />

            <CheckBox
                android:id="@+id/already_joined_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="I already joined"
                android:textColor="@android:color/white"
                android:buttonTint="#24A1DE"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/message"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/join_button"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginTop="26dp"
                android:background="@drawable/telegram_button_bg"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.03"
                android:stateListAnimator="@animator/card_press_anim"
                android:text="JOIN NOW"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                app:cornerRadius="29dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/already_joined_checkbox"
                app:layout_constraintWidth_percent="0.82" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/telegram_icon_card"
        android:layout_width="68dp"
        android:layout_height="68dp"
        app:cardCornerRadius="34dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#1C1C1E"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:background="@drawable/telegram_icon_gradient_bg"
            android:padding="16dp"
            android:src="@drawable/ic_telegram_logo"
            app:tint="@android:color/white" />
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
