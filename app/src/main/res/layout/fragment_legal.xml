<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryBlackBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/legal_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/primaryBlackBackground"
        app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
        app:navigationIconTint="?attr/textColor"
        app:title="Legal Information"
        app:titleTextColor="?attr/textColor"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="100dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/legal_toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Reading Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/legal_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="22dp"
                    android:fontFamily="@font/google_sans"
                    android:textColor="?attr/textColor"
                    android:textSize="14sp"
                    android:lineSpacingExtra="7dp"
                    tools:text="Markdown content goes here..." />

            </com.google.android.material.card.MaterialCardView>

            <!-- Footer pill -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/legal_footer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center"
                    android:fontFamily="@font/google_sans"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"
                    android:textStyle="italic"
                    tools:text="Last Edited: May 13, 2026\n© 2026 PluginStream" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>