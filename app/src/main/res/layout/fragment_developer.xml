<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryBlackBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/settings_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/primaryBlackBackground"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/settings_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/dev_profile"
            app:titleTextColor="?attr/textColor" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settings_appbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Header -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="0dp">

                    <ImageView
                        android:id="@+id/dev_profile_pic"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/profile" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/textColor"
                            android:textSize="24sp"
                            android:fontFamily="@font/google_sans"
                            android:textStyle="bold"
                            android:text="Abdul Mueed" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Developer of PluginStream"
                            android:textColor="?attr/grayTextColor"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- About Me Section (Professional & Catchy Design) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="?attr/textColor"
                            android:alpha="0.7" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="About Me"
                            android:textColor="?attr/textColor"
                            android:textSize="22sp"
                            android:fontFamily="@font/google_sans"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- ROLE SECTION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/role_label"
                            android:textColor="?attr/textColor"
                            android:alpha="0.6"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Extension-Based Multimedia &amp; Cross-Platform Developer"
                            android:textColor="?attr/textColor"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/google_sans" />
                    </LinearLayout>

                    <!-- PROFILE SECTION (Dynamic Age) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_profile_label"
                            android:textColor="?attr/textColor"
                            android:alpha="0.6"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/dev_philosophy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/textColor"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:paddingStart="16dp"
                            android:fontFamily="@font/google_sans" />
                    </LinearLayout>

                    <!-- ARCHITECTURE & TECH STACK SECTION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Architecture &amp; Tech Stack"
                            android:textColor="?attr/textColor"
                            android:alpha="0.6"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                        <!-- Architecture Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="85dp"
                                android:layout_height="wrap_content"
                                android:text="🏗️ Core"
                                android:textColor="?attr/textColor"
                                android:alpha="0.8"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Extension-Based Arch • Plugin Ecosystems"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                        </LinearLayout>

                        <!-- Mobile Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="85dp"
                                android:layout_height="wrap_content"
                                android:text="📱 Mobile"
                                android:textColor="?attr/textColor"
                                android:alpha="0.8"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kotlin Native • Jetpack Compose • Flutter"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                        </LinearLayout>

                        <!-- Web Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="85dp"
                                android:layout_height="wrap_content"
                                android:text="🌐 Backend"
                                android:textColor="?attr/textColor"
                                android:alpha="0.8"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Next.js (TS) • Node.js • Python (FastAPI)"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                        </LinearLayout>

                        <!-- Desktop Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="85dp"
                                android:layout_height="wrap_content"
                                android:text="💻 Desktop"
                                android:textColor="?attr/textColor"
                                android:alpha="0.8"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tauri • Electron • Kotlin (JVM)"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                        </LinearLayout>

                        <!-- Capabilities Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="85dp"
                                android:layout_height="wrap_content"
                                android:text="⚡ Skills"
                                android:textColor="?attr/textColor"
                                android:alpha="0.8"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ad-Blocking Engines • Video Player Integration"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                        </LinearLayout>

                        <!-- DevOps Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="85dp"
                                android:layout_height="wrap_content"
                                android:text="🔒 DevOps"
                                android:textColor="?attr/textColor"
                                android:alpha="0.8"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Docker • GitHub Actions • Secure APIs"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:fontFamily="@font/google_sans" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Catchy Quote/Developer Note Section -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="?attr/dividerColor"
                        app:cardBackgroundColor="#11FFFFFF"> <!-- Very subtle modern tint -->

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="💡 Developer Note: Built with a passion for clean code and a strictly ads-free, performance-first user experience."
                                android:textColor="?attr/grayTextColor"
                                android:textSize="13sp"
                                android:textStyle="italic"
                                android:gravity="center"
                                android:lineSpacingExtra="4dp"
                                android:fontFamily="@font/google_sans" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="Connect"
                android:textColor="?attr/textColor"
                android:alpha="0.6"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <!-- Horizontal Social Icons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <!-- GitHub -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/settings_github"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/dividerColor"
                    app:cardBackgroundColor="?attr/primaryGrayBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_github_logo"
                        app:tint="?attr/textColor" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Website -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/settings_dev_website"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/dividerColor"
                    app:cardBackgroundColor="?attr/primaryGrayBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_baseline_public_24"
                        app:tint="?attr/textColor" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Telegram -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/settings_telegram"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/dividerColor"
                    app:cardBackgroundColor="?attr/primaryGrayBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_telegram_logo"
                        app:tint="?attr/textColor" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Email -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/settings_email"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/dividerColor"
                    app:cardBackgroundColor="?attr/primaryGrayBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_email_logo"
                        app:tint="?attr/textColor" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Instagram -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/settings_instagram"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/dividerColor"
                    app:cardBackgroundColor="?attr/primaryGrayBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_instagram_logo"
                        app:tint="?attr/textColor" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/app_version_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/app_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="14sp"
                    tools:text="Version 4.0.1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/commit_hash"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="12sp"
                        tools:text="abc1234" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textColor="?attr/grayTextColor" />

                    <TextView
                        android:id="@+id/build_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="12sp"
                        tools:text="2024-03-21" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/dev_handle"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    tools:text="@PluginStream" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>