<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryBlackBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/settings_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/primaryBlackBackground"
        android:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/settings_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/dev_profile"
            app:titleTextColor="?attr/textColor" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="90dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settings_appbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ================= HERO HEADER ================= -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/dev_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/dev_banner" />

                    <!-- Soft scrim so the floating avatar always reads cleanly -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#40000000" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Floating circular avatar, overlapping banner + body -->
                <!--<com.google.android.material.card.MaterialCardView
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="-30dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="?attr/primaryBlackBackground"
                    app:cardBackgroundColor="?attr/primaryGrayBackground">

                    <ImageView
                        android:id="@+id/dev_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/dev_avatar" />
                </com.google.android.material.card.MaterialCardView>-->
            </FrameLayout>

            <!-- Name / role / mini stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/google_sans"
                        android:text="Abdul Mueed"
                        android:textColor="?attr/textColor"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="✓"
                        android:textColor="#4C9AFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/google_sans"
                    android:text="Lead Developer • PluginStream"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ================= ABOUT / BIO CARD ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="?attr/primaryGrayBackground"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.55"
                        android:fontFamily="@font/google_sans"
                        android:letterSpacing="0.06"
                        android:text="Lead Developer"
                        android:textAllCaps="true"
                        android:textColor="?attr/textColor"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/google_sans"
                        android:text="PluginStream"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/google_sans"
                        android:text="Extension-Based Multimedia Engineer"
                        android:textColor="?attr/textColor"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.55"
                        android:fontFamily="@font/google_sans"
                        android:letterSpacing="0.06"
                        android:text="About"
                        android:textAllCaps="true"
                        android:textColor="?attr/textColor"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/dev_philosophy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/google_sans"
                        android:lineSpacingExtra="5dp"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= TECH STACK ================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:alpha="0.55"
                android:fontFamily="@font/google_sans"
                android:letterSpacing="0.08"
                android:text="Architecture &amp; Tech Stack"
                android:textAllCaps="true"
                android:textColor="?attr/textColor"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="?attr/primaryGrayBackground"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Core -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_stack_icon_badge">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="🏗️"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.55"
                                android:fontFamily="@font/google_sans"
                                android:text="Core"
                                android:textColor="?attr/textColor"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/google_sans"
                                android:text="Extension-Based Arch • Plugin Ecosystems"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View style="@style/StackRowDivider" />

                    <!-- Mobile -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_stack_icon_badge">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="📱"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.55"
                                android:fontFamily="@font/google_sans"
                                android:text="Mobile"
                                android:textColor="?attr/textColor"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/google_sans"
                                android:text="Kotlin Native • Jetpack Compose • Flutter"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View style="@style/StackRowDivider" />

                    <!-- Backend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_stack_icon_badge">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="🌐"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.55"
                                android:fontFamily="@font/google_sans"
                                android:text="Backend"
                                android:textColor="?attr/textColor"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/google_sans"
                                android:text="Next.js (TS) • Node.js • Python (FastAPI)"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View style="@style/StackRowDivider" />

                    <!-- Desktop -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_stack_icon_badge">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="💻"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.55"
                                android:fontFamily="@font/google_sans"
                                android:text="Desktop"
                                android:textColor="?attr/textColor"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/google_sans"
                                android:text="Tauri • Electron • Kotlin (JVM)"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View style="@style/StackRowDivider" />

                    <!-- Skills -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_stack_icon_badge">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="⚡"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.55"
                                android:fontFamily="@font/google_sans"
                                android:text="Skills"
                                android:textColor="?attr/textColor"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/google_sans"
                                android:text="Extension Systems • Multimedia Engines • Video Player Integration • Ad-Blocking"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View style="@style/StackRowDivider" />

                    <!-- DevOps -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_stack_icon_badge">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="🔒"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.55"
                                android:fontFamily="@font/google_sans"
                                android:text="DevOps"
                                android:textColor="?attr/textColor"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/google_sans"
                                android:text="Docker • GitHub Actions • Secure APIs"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= DEVELOPER NOTE ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="?attr/primaryGrayBackground"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/google_sans"
                        android:lineSpacingExtra="3dp"
                        android:text="Built with a passion for clean code and a strictly ads-free, performance-first user experience."
                        android:textColor="?attr/grayTextColor"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= CONNECT ================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:alpha="0.55"
                android:fontFamily="@font/google_sans"
                android:letterSpacing="0.08"
                android:text="Connect"
                android:textAllCaps="true"
                android:textColor="?attr/textColor"
                android:textSize="11sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingHorizontal="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- GitHub -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_github"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="?attr/primaryGrayBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/dividerColor"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_github_logo"
                                app:tint="?attr/textColor" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:fontFamily="@font/google_sans"
                                android:text="GitHub"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Website -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_dev_website"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="?attr/primaryGrayBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/dividerColor"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_baseline_public_24"
                                app:tint="?attr/textColor" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:fontFamily="@font/google_sans"
                                android:text="Website"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Telegram -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_telegram"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="?attr/primaryGrayBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/dividerColor"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_telegram_logo"
                                app:tint="?attr/textColor" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:fontFamily="@font/google_sans"
                                android:text="Telegram"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Instagram -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_instagram"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="?attr/primaryGrayBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/dividerColor"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_instagram_logo"
                                app:tint="?attr/textColor" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:fontFamily="@font/google_sans"
                                android:text="Instagram"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Email -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_email"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="?attr/primaryGrayBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/dividerColor"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_email_logo"
                                app:tint="?attr/textColor" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:fontFamily="@font/google_sans"
                                android:text="Email"
                                android:textColor="?attr/textColor"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ================= VERSION FOOTER ================= -->
            <LinearLayout
                android:id="@+id/app_version_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <View
                    android:layout_width="36dp"
                    android:layout_height="3dp"
                    android:layout_marginBottom="16dp"
                    android:background="?attr/dividerColor" />

                <TextView
                    android:id="@+id/app_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/google_sans"
                    android:textColor="?attr/textColor"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="PluginStream v5.1.2" />

                <TextView
                    android:id="@+id/commit_hash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:alpha="0.7"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="12sp"
                    tools:text="Build 5aeb508" />

                <TextView
                    android:id="@+id/build_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.7"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="12sp"
                    tools:text="June 28, 2026" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@am-abdulmueed"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>