<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryBlackBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/settings_profile_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:id="@+id/settings_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:cardCornerRadius="30dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="?attr/white"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/settings_profile_pic"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/account"
                            android:scaleType="centerCrop"
                            tools:src="@drawable/profile_bg_orange" />

                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/settings_profile_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/textColor"
                            android:textSize="20sp"
                            android:fontFamily="@font/google_sans"
                            android:textStyle="bold"
                            tools:text="Quick Brown Fox" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/account"
                            android:textColor="?attr/grayTextColor"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 1. ACCOUNT & SECURITY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_account_security"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settings_general"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_outline_settings_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/general" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:id="@+id/settings_account"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_outline_account_circle_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/account" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:id="@+id/settings_providers"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_baseline_language_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/providers" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:id="@+id/settings_extensions"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_baseline_extension_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/extensions" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. APPEARANCE & PLAYBACK -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_appearance_playback"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settings_ui"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_baseline_color_lens_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/ui" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:id="@+id/settings_player"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_baseline_play_arrow_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/player" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. PREFERENCES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_preferences"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settings_rate_app"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_star_rate"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/rate_our_app" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:id="@+id/settings_share"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_outline_share_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/share_app" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:id="@+id/settings_bug_report"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_baseline_bug_report_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/report_a_bug" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. SYSTEM & UPDATES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_system_updates"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settings_updates"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_baseline_system_update_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/updates" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <LinearLayout
                        android:id="@+id/settings_system_compatibility"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_baseline_tv_24"
                            android:drawablePadding="16dp"
                            android:drawableTint="?attr/textColor"
                            android:text="@string/system_compatibility"
                            android:textColor="?attr/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="40dp"
                            android:layout_marginTop="2dp"
                            android:text="@string/system_compatibility_summary"
                            android:textColor="?attr/grayTextColor"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <LinearLayout
                        android:id="@+id/settings_app_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_outline_info_24"
                            android:drawablePadding="16dp"
                            android:drawableTint="?attr/textColor"
                            android:text="@string/app_info_cache"
                            android:textColor="?attr/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="40dp"
                            android:layout_marginTop="2dp"
                            android:text="@string/app_info_cache_summary"
                            android:textColor="?attr/grayTextColor"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. SUPPORT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_support"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_faq"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/baseline_help_outline_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/support_faq" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 6. ABOUT & LEGAL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_about_legal"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settings_about"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_outline_account_circle_24"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/about" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:id="@+id/settings_privacy"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_policy_icon"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/privacy_policy" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/dividerColor" />

                    <TextView
                        android:id="@+id/settings_terms"
                        style="@style/SettingsItem"
                        android:drawableStart="@drawable/ic_terms_icon"
                        android:drawablePadding="16dp"
                        android:drawableTint="?attr/textColor"
                        android:text="@string/terms_of_service" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>