<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryBlackBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/settings_profile_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <LinearLayout
                    android:id="@+id/settings_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:cardCornerRadius="30dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="?attr/white"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/settings_profile_pic"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/account"
                            android:scaleType="centerCrop"
                            tools:src="@drawable/profile_bg_orange" />

                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/settings_profile_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/textColor"
                            android:textSize="20sp"
                            android:fontFamily="@font/google_sans"
                            android:textStyle="bold"
                            tools:text="Quick Brown Fox" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/account"
                            android:textColor="?attr/grayTextColor"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Settings Options as Cards -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_general"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/ic_outline_settings_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/category_general" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_player"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/ic_baseline_play_arrow_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/category_player" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_providers"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/ic_baseline_language_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/category_providers" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_ui"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/baseline_grid_view_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/category_ui" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_updates"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/ic_baseline_system_update_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/category_updates" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_credits"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/ic_outline_info_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/category_account" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_extensions"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/baseline_grid_view_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/extensions" />
            </com.google.android.material.card.MaterialCardView>

            <!-- PREFERENCE Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_app_feedback"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_rate_app"
                    style="@style/SettingsItem"
                    android:paddingVertical="16dp"
                    android:drawableStart="@drawable/ic_star_rate"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/rate_our_app" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_share"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/ic_outline_share_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/share_plugin" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_report_bugs"
                    style="@style/SettingsItem"
                    android:drawableStart="@drawable/ic_baseline_bug_report_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/report_a_bug" />
            </com.google.android.material.card.MaterialCardView>

            <!-- SUPPORT Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_support_help"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_faq"
                    style="@style/SettingsItem"
                    android:paddingVertical="16dp"
                    android:drawableStart="@drawable/baseline_help_outline_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/support_faqs" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ABOUT & LEGAL Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/category_legal_info"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_see_with_dev"
                    style="@style/SettingsItem"
                    android:paddingVertical="16dp"
                    android:drawableStart="@drawable/ic_outline_info_24"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/about_us" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_privacy_policy"
                    style="@style/SettingsItem"
                    android:paddingVertical="16dp"
                    android:drawableStart="@drawable/ic_policy_icon"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/privacy_policy" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/dividerColor"
                app:cardBackgroundColor="?attr/primaryGrayBackground">

                <TextView
                    android:id="@+id/settings_terms"
                    style="@style/SettingsItem"
                    android:paddingVertical="16dp"
                    android:drawableStart="@drawable/ic_terms_icon"
                    android:drawablePadding="16dp"
                    android:drawableTint="?attr/textColor"
                    android:text="@string/terms_of_service" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/compose_view_contact_dialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>