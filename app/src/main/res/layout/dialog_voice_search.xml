<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/primaryBlackBackground"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/dividerColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless">

        <TextView
            android:id="@+id/voiceStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_search"
            android:textColor="?attr/textColor"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/google_sans"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Listening for your command..."
            android:textColor="?attr/grayTextColor"
            android:textSize="15sp"
            android:fontFamily="@font/google_sans"
            android:layout_marginBottom="24dp"/>

        <!-- Modern Animated Wave -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/voiceLottieAnimation"
            android:layout_width="240dp"
            android:layout_height="160dp"
            app:lottie_fileName="voice_wave.json"
            app:lottie_loop="true"
            app:lottie_autoPlay="true"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
